<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dynamic CAT Verbal App</title>
<style>
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; color: #333; max-width: 800px; margin: 0 auto; padding: 20px; }
    .card { background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 20px; }
    h1, h2 { color: #2c3e50; }
    .btn { background-color: #27ae60; color: white; border: none; padding: 12px 20px; font-size: 16px; border-radius: 5px; cursor: pointer; width: 100%; margin-top: 10px; }
    .btn:hover { background-color: #2ecc71; }
    .topic-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
    .topic-label { display: flex; align-items: center; background: #ecf0f1; padding: 10px; border-radius: 5px; cursor: pointer; }
    .topic-label input { margin-right: 10px; }
    .question-block { margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #eee; }
    .passage-box { background: #e8f8f5; padding: 15px; border-left: 4px solid #27ae60; margin-bottom: 15px; font-style: italic; line-height: 1.6; }
    .options label { display: block; margin: 8px 0; cursor: pointer; }
    #quiz-section, #results-section { display: none; }
</style>
</head>
<body>

    <!-- START SCREEN -->
    <div class="card" id="start-section">
        <h1>CAT Verbal Preparation</h1>
        <p>Select the topics you want to practice today:</p>
        
        <div class="topic-grid">
            <label class="topic-label"><input type="checkbox" value="synonyms" class="topic-check"> Synonyms</label>
            <label class="topic-label"><input type="checkbox" value="antonyms" class="topic-check"> Antonyms</label>
            <label class="topic-label"><input type="checkbox" value="grammar" class="topic-check"> Spot the Error</label>
            <label class="topic-label"><input type="checkbox" value="jumbles" class="topic-check"> Sentence Jumbles</label>
            <label class="topic-label"><input type="checkbox" value="comprehension" class="topic-check"> Reading Comprehension</label>
        </div>

        <button class="btn" onclick="startQuiz()">Load Questions & Start</button>
    </div>

    <!-- QUIZ SCREEN -->
    <div class="card" id="quiz-section">
        <div id="quiz-container"></div>
        <button class="btn" onclick="submitQuiz()">Submit Answers</button>
    </div>

    <!-- RESULTS SCREEN -->
    <div class="card" id="results-section">
        <h2>Results</h2>
        <h3 id="score-text"></h3>
        <button class="btn" onclick="location.reload()">Play Again</button>
    </div>

    <script>
        // The generator writes eng_vocab.json locally. When serving this folder with a simple HTTP server,
        // fetch('eng_vocab.json') will work. Ensure you run: python3 -m http.server 8000
        const DATABASE_URL = 'eng_vocab.json';
        
        let activeQuestions = [];
        let allData = {};

        async function startQuiz() {
            const selectedTopics = Array.from(document.querySelectorAll('.topic-check:checked')).map(cb => cb.value);
            
            if (selectedTopics.length === 0) {
                alert("Please select at least one topic.");
                return;
            }

            try {
                // Fetch data from the local file served over HTTP
                const startBtn = document.querySelector('.btn');
                startBtn.disabled = true;
                startBtn.innerText = "Loading...";

                const response = await fetch(DATABASE_URL);
                if (!response.ok) throw new Error('Network response was not ok');
                allData = await response.json();
                
                activeQuestions = [];

                // Load selected categories into the active quiz
                selectedTopics.forEach(topic => {
                    if(allData[topic]) {
                        if(topic === 'comprehension') {
                            // Comprehension has a different structure (passages)
                            allData[topic].forEach(rc => {
                                activeQuestions.push({ type: 'rc', passage: rc.passage, questions: rc.questions });
                            });
                        } else {
                            // Standard MCQs
                            allData[topic].forEach(q => {
                                activeQuestions.push({ type: 'mcq', ...q });
                            });
                        }
                    }
                });

                renderQuiz();
            } catch (error) {
                alert("Error fetching database. Make sure you are serving this folder over HTTP and that eng_vocab.json exists. " + error.message);
                document.querySelector('.btn').innerText = "Load Questions & Start";
                document.querySelector('.btn').disabled = false;
            }
        }

        function renderQuiz() {
            document.getElementById('start-section').style.display = 'none';
            document.getElementById('quiz-section').style.display = 'block';
            
            const container = document.getElementById('quiz-container');
            container.innerHTML = '';

            let questionCounter = 0;

            activeQuestions.forEach((item, index) => {
                if (item.type === 'mcq') {
                    questionCounter++;
                    container.innerHTML += buildMCQHTML(item, questionCounter, index);
                } else if (item.type === 'rc') {
                    container.innerHTML += `<div class="passage-box"><strong>Read the Passage:</strong><br>${item.passage}</div>`;
                    item.questions.forEach((q, qIndex) => {
                        questionCounter++;
                        container.innerHTML += buildMCQHTML(q, questionCounter, `${index}-${qIndex}`);
                    });
                }
            });
        }

        function buildMCQHTML(q, qNum, idString) {
            let optionsHTML = q.options.map(opt => 
                `<label><input type="radio" name="q_${idString}" value="${opt}"> ${opt}</label>`
            ).join('');

            return `
                <div class="question-block" data-answer="${q.answer}" data-name="q_${idString}">
                    <p><strong>${qNum}. ${q.question}</strong></p>
                    <div class="options">${optionsHTML}</div>
                </div>
            `;
        }

        function submitQuiz() {
            let score = 0;
            let total = 0;
            const blocks = document.querySelectorAll('.question-block');
            
            blocks.forEach(block => {
                total++;
                const correctAnswer = block.getAttribute('data-answer');
                const radioName = block.getAttribute('data-name');
                const selected = document.querySelector(`input[name="${radioName}"]:checked`);
                
                if (selected && selected.value === correctAnswer) {
                    score++;
                }
            });

            document.getElementById('quiz-section').style.display = 'none';
            document.getElementById('results-section').style.display = 'block';
            document.getElementById('score-text').innerText = `You scored ${score} out of ${total}!`;
        }
    </script>
</body>
</html>
